{
  "name": "helm-desktop",
  "productName": "Helm",
  "version": "1.0.0",
  "description": "Helm — your personal AI assistant, on your own machine",
  "main": "main.js",
  "author": "Helm",
  "homepage": "https://goodman-pro.github.io/helm/",
  "scripts": {
    "dev": "electron .",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux"
  },
  "devDependencies": {
    "electron": "^42.0.0",
    "electron-builder": "^26.0.0",
    "electron-is-dev": "^3.0.1"
  },
  "build": {
    "appId": "com.helm.desktop",
    "productName": "Helm",
    "copyright": "Helm",
    "directories": { "buildResources": "build", "output": "dist" },
    "files": ["main.js", "preload.js", "index.html", "logo.svg", "build/icon.*"],
    "publish": [{ "provider": "github", "owner": "GOODMAN-PRO", "repo": "helm" }],
    "mac": {
      "target": [{ "target": "dmg", "arch": ["arm64", "x64"] }, { "target": "zip", "arch": ["arm64", "x64"] }],
      "category": "public.app-category.productivity",
      "icon": "build/icon.png",
      "identity": null,
      "artifactName": "Helm-${version}-${arch}.${ext}"
    },
    "dmg": { "title": "Helm ${version}", "artifactName": "Helm-${version}-${arch}.${ext}" },
    "win": {
      "target": [{ "target": "nsis", "arch": ["x64"] }],
      "icon": "build/icon.png",
      "artifactName": "Helm-Setup-${version}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "Helm"
    },
    "linux": {
      "target": ["AppImage"],
      "icon": "build/icon.png",
      "category": "Utility",
      "artifactName": "Helm-${version}.${ext}"
    }
  }
}
