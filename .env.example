# Copy this to .env on the new machine and fill in DISCORD_TOKEN + OWNER_ID.
# (The installer fills these in for you when run interactively.)
DISCORD_TOKEN=paste-your-discord-bot-token-here
OWNER_ID=your-discord-user-id
# How Helm is powered:
#   subscription = Claude Pro/Max via the claude login (no per-message cost)
#   apikey       = pay-as-you-go; also set ANTHROPIC_API_KEY below
#   custom       = free / local model via any Anthropic-compatible endpoint
#                  (Ollama, Groq, OpenRouter free tiers, a LiteLLM proxy, ...)
#                  set ANTHROPIC_BASE_URL + ANTHROPIC_MODEL (+ ANTHROPIC_API_KEY if it needs one)
#   vertex       = real Claude on Google Vertex AI (gcloud auth; great with the $300 free-trial credits)
AUTH_MODE=subscription
# ANTHROPIC_API_KEY=sk-ant-...        # AUTH_MODE=apikey (or a key for your custom endpoint)
# ANTHROPIC_BASE_URL=http://localhost:11434   # AUTH_MODE=custom — your model endpoint (Ollama native API)
# ANTHROPIC_MODEL=llama3.1                     # AUTH_MODE=custom — model id at that endpoint
#
# Free ONLINE model (Gemini / Groq / OpenRouter / Cerebras / Together): set AUTH_MODE=custom and the
# three OPENAI_* vars below. Helm auto-starts a local proxy (workspace/proxy/llm-proxy.mjs) that
# translates Claude Code's Anthropic API to the provider's OpenAI-compatible API — no ANTHROPIC_* needed.
# Recommended free: Google Gemini (AI Studio) — free tier, 1M context, fast. Key: https://aistudio.google.com/apikey
# OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# OPENAI_MODEL=gemini-2.0-flash                 # or gemini-2.5-flash
# OPENAI_API_KEY=AIza...
# Or another provider (Groq shown):
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=gsk_...                       # free key from the provider's console
# PROXY_PORT=8787                              # local proxy port (default 8787)
#
# Claude on Google VERTEX AI (real Claude, billed to Google Cloud — works great with the $300 free trial).
# Set AUTH_MODE=vertex. Helm talks to Vertex natively (no proxy). Auth = gcloud Application Default
# Credentials — install gcloud, then run once:   gcloud auth application-default login
# Also: enable the Vertex AI API and enable Claude in Vertex Model Garden for your project.
# GCP_PROJECT_ID=my-gcp-project-id
# VERTEX_REGION=us-east5                        # a region where you enabled Claude in Model Garden
# VERTEX_MODEL=claude-sonnet-4-5@20250929       # exact model id from Model Garden (name@version)
MODEL=opus
# default = Helm asks before each tool action (safer; recommended to start).
# bypassPermissions = full autonomy, acts without asking. Switch once you trust it on this machine.
PERMISSION_MODE=default
CLAUDE_BIN=claude
WORKSPACE=./workspace
#
# Helm network (optional) — connect to other people's Helms as friends through a relay hub.
# Leave unset to stay solo. The hub only relays signed messages; friends are always UNTRUSTED.
# HELM_HUB_URL=https://your-hub.example.com
