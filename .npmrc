# Helm needs Node >=22.5.0 (it uses the built-in node:sqlite module, added in 22.5).
# engine-strict makes `npm install` fail FAST with a clear "Unsupported engine" message on older
# Node instead of installing fine and then crashing at first run with a cryptic ERR_UNKNOWN_BUILTIN_MODULE.
engine-strict=true
# Quieter installs so the real errors aren't buried.
fund=false
audit=false
