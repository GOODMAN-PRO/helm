# secrets / deps / state
node_modules/
.env
.env.bak*
.env.local
.env.*.bak
*.log
*.db
*.db-wal
*.db-shm

# session + run artifacts
workspace/.sessions.json
workspace/.imessage-sessions.json
workspace/runs/*
!workspace/runs/*.mjs
workspace/browser-profile/
workspace/browser-state.json
workspace/downloads/

# captured media (screenshots, audio, ocr buffers)
*.png
*.jpg
*.jpeg
*.gif
*.wav
*.mp3
*.m4a

# compiled binaries (rebuilt from source)
bin/guicontrol
bin/ocr-helper

# Swift/Xcode build output (regenerated by `swift build` — never commit)
.build/
**/.build/
*.xcodeproj/xcuserdata/
DerivedData/

# self-upgrade lock
.upgrade.lock

# background cognition (derived/state)
workspace/think/journal/
workspace/think/.think.lock
workspace/memory/INDEX.md

# fleet: per-machine active target
workspace/active-target

# swarm worktrees
.swarm/
workspace/swarm/swarm.log

workspace/swarm/diffs/
workspace/swarm/bugsweep.json.bak

# secrets vault (encrypted, but never commit)
workspace/secrets/vault.json

workspace/inbox/

workspace/research/reports/
workspace/research/research.log

workspace/conversations/

workspace/reverse/
workspace/costs/*.db

# stuck queue (runtime state for nightly self-upgrade)
workspace/upgrades/stuck-queue.jsonl
workspace/upgrades/stuck-archive.jsonl

# per-install template flavor + exported templates (user-generated/shareable)
workspace/persona.local.md
workspace/templates/*.helmtemplate.json

# Helm Mind nightly agent log
workspace/mind/mind.log

# ---- owner-generated / personal workspace state (NEVER publish) ----
# Helm's onboarding writes the owner's profile here; keep it private.
workspace/owner.md
workspace/owner.local.md
# fleet setup notes (the other machine's SSH host / Tailscale name — private)
workspace/fleet.md
# personal projects, plans and status the agent generates while working
workspace/business/
workspace/companies/
workspace/status.md
# personal study material (exam drills / question banks the agent generates)
workspace/drills/
# personal scheduler jobs (the scheduler engine stays tracked; jobs are per-owner)
workspace/scheduler/exam-countdown.mjs
# generated upgrade/sweep reports, prompts and logs (code in this dir stays tracked)
workspace/upgrades/*_REPORT.md
workspace/upgrades/*_PROGRESS.md
workspace/upgrades/*_REVIEW.md
workspace/upgrades/PLAN.md
workspace/upgrades/UPGRADE_LOG.md
workspace/upgrades/*-prompt.txt
workspace/upgrades/sweep-*.txt
# swarm runtime task lists + reports (swarm engine stays tracked)
workspace/swarm/*.json
workspace/swarm/REPORT.md
# captured browser pages
workspace/.playwright-mcp/

# runtime error logs
*.err

# keyprobe diagnostic capture
workspace/diag/*.out

# liveness marker (written on Discord connect; read by the nightly upgrade health-check)
workspace/.online
# restart hand-off marker (written by the Discord `restart` command, cleared on next boot)
workspace/.restarting

# brain console log (runtime)
workspace/helm.log

# owner project tracker (personal)
workspace/projects.json

# Helm network: private identity key, friend list, hub relay store
workspace/network/identity.json
workspace/network/friends.json
workspace/network/hub-data.json
