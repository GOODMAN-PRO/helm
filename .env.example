# Copy this to .env on the new machine and fill in DISCORD_TOKEN + OWNER_ID.
# (The installer fills these in for you when run interactively.)
DISCORD_TOKEN=paste-your-discord-bot-token-here
OWNER_ID=your-discord-user-id
# How Helm is powered:
#   subscription = Claude Pro/Max via the claude login (no per-message cost)
#   apikey       = pay-as-you-go; also set ANTHROPIC_API_KEY below
#   custom       = free / local model via any Anthropic-compatible endpoint
#                  (Ollama, Groq, OpenRouter free tiers, a LiteLLM proxy, ...)
#                  set ANTHROPIC_BASE_URL + ANTHROPIC_MODEL (+ ANTHROPIC_API_KEY if it needs one)
AUTH_MODE=subscription
# ANTHROPIC_API_KEY=sk-ant-...        # AUTH_MODE=apikey (or a key for your custom endpoint)
# ANTHROPIC_BASE_URL=http://localhost:11434   # AUTH_MODE=custom — your model endpoint (Ollama native API)
# ANTHROPIC_MODEL=llama3.1                     # AUTH_MODE=custom — model id at that endpoint
#
# Free ONLINE model (Groq / OpenRouter / Cerebras / Together): set AUTH_MODE=custom and the three
# OPENAI_* vars below. Helm auto-starts a local proxy (workspace/proxy/llm-proxy.mjs) that translates
# Claude Code's Anthropic API to the provider's OpenAI-compatible API — no ANTHROPIC_* needed.
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_MODEL=llama-3.3-70b-versatile
# OPENAI_API_KEY=gsk_...                       # free key from the provider's console
# PROXY_PORT=8787                              # local proxy port (default 8787)
MODEL=opus
PERMISSION_MODE=bypassPermissions
CLAUDE_BIN=claude
WORKSPACE=./workspace
#
# Fleet — an OPTIONAL second machine, as an EQUAL peer (not subordinate). Each machine runs its own
# full Helm; "use mac"/"use windows" picks which peer is active, and the active peer does all the work
# locally. Point these at the OTHER peer (works on either OS — the names are historical):
# HELM_WIN_HOST=you@other-host        # SSH target of the other peer (LAN IP or Tailscale name)
# HELM_WIN_CLAUDE=claude              # path to the claude CLI on the other peer (optional)
# HELM_WIN_DIR=helm                   # the other peer's Helm install dir (full code+tools, for parity)
