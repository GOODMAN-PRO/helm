# Copy this to .env on the new machine and fill in DISCORD_TOKEN + OWNER_ID.
# (The installer fills these in for you when run interactively.)
DISCORD_TOKEN=paste-your-discord-bot-token-here
OWNER_ID=your-discord-user-id
# How Helm is powered:
#   subscription = Claude Pro/Max via the claude login (no per-message cost)
#   apikey       = pay-as-you-go; also set ANTHROPIC_API_KEY below
#   custom       = free / local model via any Anthropic-compatible endpoint
#                  (Ollama, Groq, OpenRouter free tiers, a LiteLLM proxy, ...)
#                  set ANTHROPIC_BASE_URL + ANTHROPIC_MODEL (+ ANTHROPIC_API_KEY if it needs one)
AUTH_MODE=subscription
# ANTHROPIC_API_KEY=sk-ant-...        # AUTH_MODE=apikey (or a key for your custom endpoint)
# ANTHROPIC_BASE_URL=http://localhost:11434   # AUTH_MODE=custom — your model endpoint
# ANTHROPIC_MODEL=llama3.1                     # AUTH_MODE=custom — model id at that endpoint
MODEL=opus
PERMISSION_MODE=bypassPermissions
CLAUDE_BIN=claude
WORKSPACE=./workspace
