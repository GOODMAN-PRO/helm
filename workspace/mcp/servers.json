{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "__HELM_ROOT__"],
      "healthCheck": false,
      "enabled": true
    },
    "fetch": {
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-fetch"],
      "healthCheck": "initialize",
      "comment": "Disabled: that npm package does not exist (the official fetch server is Python-only); Claude Code's built-in WebFetch already covers this.",
      "enabled": false
    },
    "playwright": {
      "command": "npx",
      "args": ["-y", "@playwright/mcp@latest", "--headless"]
    },
    "github": {
      "command": "node",
      "args": ["__HELM_ROOT__/workspace/mcp/wrap-github.mjs"],
      "healthCheck": "initialize",
      "enabled": true
    },
    "google-workspace": {
      "command": "node",
      "args": ["__HELM_ROOT__/workspace/mcp/wrap-google-workspace.mjs"],
      "healthCheck": "initialize",
      "enabled": true
    },
    "brave-search": {
      "command": "node",
      "args": ["__HELM_ROOT__/workspace/mcp/wrap-brave-search.mjs"],
      "healthCheck": "initialize",
      "enabled": true
    }
  }
}
